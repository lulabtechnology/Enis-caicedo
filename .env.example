# IDX / ACOBIR RealtyServer
IDX_FTP_HOST=ftp.realtyserver.com
IDX_FTP_USER=
IDX_FTP_PASSWORD=
IDX_FTP_SECURE=false
IDX_FEEDS=res,com
IDX_DOWNLOAD_PHOTOS=true
IDX_MAX_PHOTOS_PER_LISTING=12

# Debug opcional
IDX_FTP_VERBOSE=false
IDX_INCLUDE_RAW=false

# Control de fotos para GitHub Actions / sincronización larga
IDX_PHOTO_TIME_BUDGET_MINUTES=45
IDX_PHOTO_PROGRESS_EVERY=10
IDX_PHOTO_FETCH_TIMEOUT_MS=20000
